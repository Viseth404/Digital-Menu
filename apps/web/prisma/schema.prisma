generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MERCHANT
  STAFF
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum MerchantMemberRole {
  OWNER
  MANAGER
  STAFF
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  passwordHash     String
  role             UserRole         @default(STAFF)
  isActive         Boolean          @default(true)
  sessions         Session[]
  adminAuditLogs   AdminAuditLog[]
  memberships      MerchantMember[]
  createdMerchants Merchant[]       @relation("CreatedMerchants")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AdminAuditLog {
  id         String  @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  targetName String?
  details    Json?
  ipAddress  String?

  admin User @relation(fields: [adminId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}

model PlatformSetting {
  id                  String  @id @default("platform")
  maintenanceMode     Boolean @default(false)
  announcement        String?
  supportEmail        String  @default("admin@savor.com")
  defaultCurrency     String  @default("USD")
  uploadLimitMb       Int     @default(5)
  sessionDurationDays Int     @default(7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Merchant {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  status       MerchantStatus @default(PENDING)
  contactEmail String
  phone        String?

  createdById String
  createdBy   User             @relation("CreatedMerchants", fields: [createdById], references: [id], onDelete: Restrict)
  members     MerchantMember[]
  stores      Store[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([status])
}

model MerchantMember {
  id         String             @id @default(cuid())
  merchantId String
  userId     String
  role       MerchantMemberRole @default(STAFF)

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([merchantId, userId])
  @@index([userId])
}

model Store {
  id            String      @id @default(cuid())
  merchantId    String
  name          String
  slug          String
  description   String?
  status        StoreStatus @default(ACTIVE)
  isPublished   Boolean     @default(false)
  address       String?
  phone         String?
  email         String?
  logoUrl       String?
  coverImageUrl String?
  primaryColor  String      @default("#166534")
  accentColor   String      @default("#F0FDF4")
  facebookUrl   String?
  instagramUrl  String?
  telegramUrl   String?
  tiktokUrl     String?
  timezone      String      @default("Asia/Phnom_Penh")
  currency      String      @default("USD")
  exchangeRate  Decimal     @default(1) @db.Decimal(12, 4)

  merchant   Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products   Product[]
  categories Category[]
  tables     DiningTable[]
  orders     Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([merchantId, slug])
  @@index([merchantId])
  @@index([status])
}

model DiningTable {
  id         String  @id @default(cuid())
  storeId    String
  number     Int
  name       String?
  isActive   Boolean @default(true)
  orderToken String  @unique @default(uuid())

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, number])
  @@index([storeId, isActive])
}

model Category {
  id          String  @id @default(cuid())
  storeId     String
  name        String
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model Product {
  id          String  @id @default(cuid())
  storeId     String
  categoryId  String?
  name        String
  description String?
  price       Decimal @db.Decimal(12, 2)
  imageUrl    String?
  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isAvailable])
  @@index([categoryId])
}

model Order {
  id       String      @id @default(cuid())
  storeId  String
  tableId  String
  status   OrderStatus @default(PENDING)
  subtotal Decimal     @db.Decimal(12, 2)
  currency String
  note     String?

  store Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table DiningTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, status, createdAt])
  @@index([tableId, createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  unitPrice   Decimal @db.Decimal(12, 2)
  quantity    Int
  lineTotal   Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
